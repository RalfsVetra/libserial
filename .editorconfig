root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 80

[*.{cc,ccm}]
indent_style = space
indent_size = 4

[CMakeLists.txt]
indent_style = space
indent_size = 4